#include<stdio.h>
int main(){
    int n,bt[20],at[20],wt[20],tat[20],ct[20];
    float avgwt, avgtat,sumwt=0,sumtat=0;
    printf("no of procrdure ");
    scanf("%d",&n);
    printf("arrival time");
    for (int i=0;i<n;i++){
        scanf("%d",&at[i]);

    }
    printf("burst time");
    for (int i=0;i<n;i++){
        scanf("%d",&bt[i]);

    }
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if(at[i]>at[j]){
                int temp=at[j];
                at[j]=at[i];
                at[i]=temp;
                int t=bt[j];
                bt[j]=bt[i];
                bt[i]=t;


            }
        }
    }
    ct[0]=bt[0]+at[0];
    for(int i=1;i<n;i++){
        if(ct[i-1]<at[i]){
            ct[i]=at[i]+bt[i];

        }
        else{
            ct[i]=ct[i-1]+bt[i];


        }

    }
    for(int i=0;i<n;i++){
        tat[i]=ct[i]-at[i];
        wt[i]=tat[i]-bt[i];

    }

    for(int i=0;i<n;i++){
        sumwt+=wt[i];
        sumtat+=tat[i];
    }
    avgtat=sumtat/n;
    avgwt=sumwt/n;
    printf("\n AT \t BT \t CT \t TAT \t WT\n");
    for(int i=0;i<n;i++){
        printf("%d\t %d\t %d\t %d\t %d\t\n ",at[i],bt[i],ct[i],tat[i],wt[i]);


    }
    printf("avg tat %f avg wt%f",avgtat,avgwt);





}
